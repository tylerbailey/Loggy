@page "/"
@using Loggy.Models.Logs.Classes
@using Loggy.Web.ApiClients
@using Loggy.Models.Gemini
@using Loggy.Models
@using Microsoft.AspNetCore.Components.Forms
@using System.Text.Json
@inject LogUploadApiClient logUploadApi
@inject AnalysisApiClient analysisApiClient
@rendermode InteractiveServer

<div class="container">
    <div class="row mb-3">
        <div class="col-auto me-3">
            <InputFile id="file-upload" class="form-control" OnChange="OnFileChange" />
        </div>
        @if (logs != null && logs.Count() > 0 && !String.IsNullOrEmpty(selectedSortKey))
        {
            <div class="col-auto me-3">
                <select class="form-select" id="modelTypeSelect" @bind="modelTypeSelected">
                    <option value="0">Gemini-2.5-flash</option>
                </select>
            </div>

            <div class="col-auto">
                <button type="button" id="analyze-button" class="btn btn-success" @onclick="AnalyzeLogs">Analyze</button>
            </div>
        }
    </div>

    <div class="row mb-3">
    @if (sortKeys.Count > 0)
    {
            <div class="col-4">
                <div class="card mb-3">
                    <div class="card-body">
                        <h5 class="card-title">Group By</h5>
                        <ul class="list-group">
                            @foreach (var key in sortKeys)
                            {
                                var sortKey = key;
                                    <a class="list-group-item list-group-item-action @(sortKey == selectedSortKey ? "active" : "")" href="" @onclick="() => selectedSortKey = sortKey">@key</a>
                            }
                        </ul>
                    </div>
                </div>
            </div>
    }

    @if (!String.IsNullOrEmpty(selectedSortKey))
    {
            <div class="col-8">
                <div class="card">
                    <div class="card-body">
                        <h5 class="card-title">Logs</h5>
                        <div class="accordion" id="exceptionAccordion">
                            @foreach (var (logGroupKey, index) in groupedLogs.Keys.Select((key, i) => (key, i)))
                            {
                                <div class="accordion-item">
                                    <h2 class="accordion-header">
                                        <button class="accordion-button collapsed"
                                                type="button"
                                                data-bs-toggle="collapse"
                                                data-bs-target="@($"#collapseItem{index}")"
                                                aria-expanded="false"
                                                aria-controls="@($"collapseItem{index}")">
                                            @logGroupKey
                                        </button>
                                    </h2>
                                    <div id="@($"collapseItem{index}")"
                                         class="accordion-collapse collapse"
                                         data-bs-parent="#exceptionAccordion">
                                        <div class="accordion-body">
                                            @foreach (var item in groupedLogs[logGroupKey])
                                            {
                                                <ul class="list-group list-group-flush mb-3">
                                                    @* @foreach (var property in item.Schema.Keys)
                                                    {
                                                        <li class="@GetHighlightClass(item.Id)"><strong>@property:</strong> @item.Schema[property]</li>
                                                    } *@
                                                </ul>
                                            }
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            </div>
    }
    </div>

    @if (analysisResult != null)
    {
        <div class="row mb-3">
            <div class="col-12">
                <div class="card mb-3">
                    <div class="card-body">
                        <h5 class="card-title">Summary</h5>
                        <p class="card-text">@analysisResult.Summary</p>
                    </div>
                </div>

                <div class="card mb-3">
                    <div class="card-body">
                        <h5 class="card-title">Error Counts</h5>
                        <ul class="list-group list-group-flush">
                            <li class="list-group-item text-danger">Critical: @analysisResult.ErrorCounts.Critical</li>
                            <li class="list-group-item text-danger">Errors: @analysisResult.ErrorCounts.Errors</li>
                            <li class="list-group-item text-warning">Warnings: @analysisResult.ErrorCounts.Warnings</li>
                            <li class="list-group-item text-info">Info: @analysisResult.ErrorCounts.Info</li>
                        </ul>
                    </div>
                </div>

                @foreach (var pattern in analysisResult.Patterns)
                {
                    <div class="card mb-2">
                        <div class="card-body">
                            <h6 class="card-title">
                                <span class="badge bg-@GetSeverityColor(pattern.Severity)">@pattern.Severity</span>
                                @pattern.Title
                            </h6>
                            <p class="card-text">@pattern.Description</p>
                            <p class="card-text"><strong>Recommendation:</strong> @pattern.Recommendation</p>
                        </div>
                    </div>
                }
            </div>
        </div>
    }
</div>

@code {
    private string _selectedSortKey = String.Empty;
    private int modelTypeSelected = 0;
    private List<LogEvent> logs = new List<LogEvent>();
    private List<string> sortKeys = new List<string>();
    private Dictionary<string, List<LogEvent>> groupedLogs = new Dictionary<string, List<LogEvent>>();
    private LogAnalysis? analysisResult;

    private string selectedSortKey
    {
        get { return _selectedSortKey; }
        set { _selectedSortKey = value; InvokeAsync(OnSortKeyChange); }
    }

    private async Task OnFileChange(InputFileChangeEventArgs e)
    {
        await GetLogsFromFile(e.File);
        StateHasChanged();
    }

    public async Task AnalyzeLogs()
    {
        if (logs == null) return;
        analysisResult = await analysisApiClient.AnalyzeLogsAsync(logs, modelTypeSelected);
        StateHasChanged();
    }

    public async Task GetLogsFromFile(IBrowserFile? logFile)
    {
        if (logFile == null) return;
        logs = JsonSerializer.Deserialize<List<LogEvent>>(await logUploadApi.UploadLogAsync(logFile), new JsonSerializerOptions { PropertyNameCaseInsensitive = true }) ?? [];
        if (logs.Count == 0) return;
        sortKeys = await logUploadApi.GetSortKeys(logs) ?? [];
        selectedSortKey = sortKeys.FirstOrDefault() ?? "";
        StateHasChanged();
    }

    public async Task OnSortKeyChange()
    {
        groupedLogs = await logUploadApi.GroupBy(logs, selectedSortKey);
        StateHasChanged();
    }

    private string GetSeverityColor(string severity) => severity switch
    {
        "Critical" => "danger",
        "High" => "danger",
        "Medium" => "warning",
        "Low" => "secondary",
        "Info" => "info",
        _ => "secondary"
    };

    private string GetHighlightClass(int id)
    {
        if (analysisResult?.Patterns == null) return "";
        return analysisResult.Patterns.Any(p => p.RelatedEventIds.Contains(id))
            ? "list-group-item list-group-item-" + GetSeverityColor(analysisResult.Patterns.Where(p => p.RelatedEventIds.Contains(id)).FirstOrDefault()?.Severity ?? "secondary")
            : "list-group-item";
    }
}